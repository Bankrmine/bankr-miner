# Phase 2 (Bankr-wired) configuration.
# Copy to `.env.local` and fill in. Phase 1 demo runs without any of these.

# Get from https://bankr.bot/api with Agent API + Wallet API enabled.
BANKR_API_KEY=bk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set after launching $MINE via `node scripts/bankr-launch.mjs`
# or `bankr launch` CLI. Must be a deployed ERC-20 on Base.
MINE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Optional. Wallet API always transfers from the wallet bound to the
# API key; this is just a hint logged on startup so deployers can
# double-check they wired the right key.
# BANKR_TREASURY_WALLET=0x0000000000000000000000000000000000000000
