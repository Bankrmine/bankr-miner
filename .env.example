# Live-mode (Bankr-wired) configuration.
# Copy to `.env.local` and fill in. The pre-launch preview runs without any of these.

# Get from https://bankr.bot/api. Required toggles on the key:
#   - Wallet API
#   - Agent API
#   - Token Launch API   (only needed if you deploy $MINE from this machine)
#   - Read Only Mode = OFF
BANKR_API_KEY=bk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set after launching $MINE via `node scripts/bankr-launch.mjs`.
# Must be a deployed ERC-20 on Base. Until this is set, /api/mine
# returns a `0xmock...` tx hash and the network badge stays in
# "pre-launch preview" mode.
MINE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Optional. Wallet API always transfers from the wallet bound to the
# API key; this is just a hint logged on startup so deployers can
# double-check they wired the right key.
# BANKR_TREASURY_WALLET=0x0000000000000000000000000000000000000000

# Optional. Used by metadataBase for social og:image resolution on
# previews / staging. Defaults to https://bankr-miner.app.
# NEXT_PUBLIC_SITE_URL=https://bankr-miner.vercel.app
